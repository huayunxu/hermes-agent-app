<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Hermes is typically deployed on private LAN with HTTP Web UI + Gateway -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
